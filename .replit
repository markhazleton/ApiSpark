modules = ["web", "dotnet-10.0"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd src/ApiSpark.Api && dotnet run --urls=http://0.0.0.0:5000 --environment=Development"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["dotnet", "src/ApiSpark.Api/ApiSpark.Api.dll", "--urls=http://0.0.0.0:5000"]
build = ["dotnet", "publish", "src/ApiSpark.Api/ApiSpark.Api.csproj", "-c", "Release", "-o", "publish"]
